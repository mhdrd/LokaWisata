// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// --- ENUM UNTUK STATUS & ROLE ---
enum Role {
  ADMIN
  USER
}

enum BookingStatus {
  PENDING
  SUCCESS
  CANCELLED
}

// --- MODEL DATABASE ---
model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     Role   @default(USER) // untuk membedakan Admin CMS dan End-User

  // Relasi: 1 User bisa punya banyak Booking
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kategori {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  // Relasi: 1 Kategori bisa dimiliki banyak Tempat Wisata
  wisatas Wisata[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wisata {
  id          Int     @id @default(autoincrement())
  name        String
  description String? @db.Text
  price       Float // Harga tiket masuk
  quota       Int     @default(0) // Kuota tiket per hari

  // Koordinat sangat penting untuk API Cuaca (Open-Meteo)
  latitude  Float?
  longitude Float?

  kategoriId Int
  kategori   Kategori @relation(fields: [kategoriId], references: [id])

  // Relasi: 1 Tempat Wisata bisa dibooking berkali-kali
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  wisataId Int
  wisata   Wisata @relation(fields: [wisataId], references: [id])

  bookingDate DateTime // Tanggal turis akan datang berkunjung
  quantity    Int // Jumlah tiket yang dibeli
  totalPrice  Float // Hasil dari (quantity * Wisata.price)
  status      BookingStatus @default(PENDING) // Status pemesanan

  createdAt DateTime @default(now()) // Waktu saat transaksi dilakukan
  updatedAt DateTime @updatedAt
}
